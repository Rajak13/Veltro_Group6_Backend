{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=Veltro;Username=postgres;Password=postgres"
  },
  "JwtSettings": {
    "SecretKey": "veltro-super-secret-jwt-key-minimum-32-chars",
    "Issuer": "VeltroAPI",
    "Audience": "VeltroClient",
    "ExpiryInDays": 7
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "your-email@gmail.com",
    "SenderPassword": "your-app-password",
    "SenderName": "Veltro System"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigin": "https://your-production-url.com"
}
